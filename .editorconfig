# Specifications: https://spec.editorconfig.org/

# top-most EditorConfig file
root = true

# settings configured to match prettier + eslint rules
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Specific configs
[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.sql]
indent_size = 2

[*.json]
indent_size = 2

[openapi.json]
insert_final_newline = false

[*.kt]
# this rule disallows underscores, which are technically valid in package names
ktlint_standard_package-name = disabled
ktlint_standard_no-unused-imports = enabled
